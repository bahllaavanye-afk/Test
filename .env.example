# QuantEdge Environment Variables
# Copy to .env and fill in your values

# App
TRADING_MODE=paper
DEBUG=true
ALLOWED_ORIGINS=http://localhost:5173

# Security (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=change-me-in-production-32-byte-hex

# Database (Supabase in production)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/quantedge
ALEMBIC_DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/quantedge

# Redis (Upstash in production)
# Supabase: postgresql+asyncpg://postgres.PROJECTREF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres
# Note: URL-encode special chars in password (@ → %40, # → %23)

# Redis (Upstash in production)
# Get TLS Redis URL from: https://console.upstash.com → Redis → Connect → rediss:// URL
REDIS_URL=redis://localhost:6379
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Alpaca (paper by default)
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# TradeStation
TRADESTATION_CLIENT_ID=
TRADESTATION_SECRET=
TRADESTATION_PAPER=true

# Polymarket
POLYMARKET_PRIVATE_KEY=

# News/Sentiment (optional, free tier)
NEWSAPI_KEY=

# ML
MODELS_DIR=models_artifacts

# Slack notifications (optional — each channel has its own webhook URL)
# Create webhooks at: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_DEFAULT=
SLACK_WEBHOOK_ORDERS=
SLACK_WEBHOOK_SIGNALS=
SLACK_WEBHOOK_ALERTS=
SLACK_WEBHOOK_EXPERIMENTS=
SLACK_WEBHOOK_SYSTEM=
