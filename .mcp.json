{
  "mcpServers": {
    "perplexity": {
      "type": "stdio",
      "command": "npx",
      "args": ["-yq", "@perplexity-ai/mcp-server"],
      "env": {
        "PERPLEXITY_API_KEY": "${PERPLEXITY_API_KEY}"
      }
    },
    "alpaca": {
      "type": "stdio",
      "command": "npx",
      "args": ["-yq", "@alpacahq/alpaca-mcp-server"],
      "env": {
        "ALPACA_API_KEY": "${ALPACA_API_KEY}",
        "ALPACA_SECRET_KEY": "${ALPACA_SECRET_KEY}",
        "ALPACA_PAPER": "true"
      }
    },
    "supabase": {
      "type": "stdio",
      "command": "npx",
      "args": ["-yq", "@supabase/mcp-server"],
      "env": {
        "SUPABASE_ACCESS_TOKEN": "${SUPABASE_ACCESS_TOKEN}"
      }
    },
    "redis": {
      "type": "stdio",
      "command": "npx",
      "args": ["-yq", "@redis/mcp-server"],
      "env": {
        "REDIS_URL": "${REDIS_URL}"
      }
    },
    "slack": {
      "type": "stdio",
      "command": "npx",
      "args": ["-yq", "@modelcontextprotocol/server-slack"],
      "env": {
        "SLACK_BOT_TOKEN": "${SLACK_BOT_TOKEN}",
        "SLACK_TEAM_ID": "${SLACK_TEAM_ID}"
      }
    }
  }
}
